generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────── ENUMS ───────────────

enum UserRole {
  PATIENT
  DOCTOR
  ADMIN
  RECEPTIONIST
  FINANCE
}

enum Gender {
  MALE
  FEMALE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  RESCHEDULED
}

enum AppointmentType {
  NEW_VISIT
  FOLLOW_UP
  CONSULTATION
  EMERGENCY
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_PAID
  REFUNDED
  WAIVED
}

enum PaymentMethod {
  CASH
  CARD
  INSURANCE
  ONLINE
}

enum LabResultStatus {
  PENDING
  COMPLETED
  ABNORMAL
  CRITICAL
}

enum NotificationType {
  APPOINTMENT_REMINDER
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  LAB_RESULT_READY
  PRESCRIPTION_READY
  BILL_GENERATED
  PAYMENT_SUCCESS
  SYSTEM_ALERT
}

enum NotificationChannel {
  PUSH
  SMS
  IN_APP
}

enum DayOfWeek {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

// ─────────────── USERS & AUTH ───────────────

model User {
  id          String   @id @default(uuid())
  phone       String   @unique
  role        UserRole
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient       Patient?
  doctor        Doctor?
  admin         Admin?
  otpCodes      OtpCode[]
  sessions      Session[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@map("users")
}

model OtpCode {
  id        String   @id @default(uuid())
  userId    String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_codes")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─────────────── PATIENTS ───────────────

model Patient {
  id               String    @id @default(uuid())
  userId           String    @unique
  mrn              String    @unique
  nameAr           String
  nameEn           String?
  dateOfBirth      DateTime
  gender           Gender
  nationalId       String?   @unique
  email            String?
  bloodType        String?
  allergies        String[]
  chronicDiseases  String[]
  emergencyContact Json?
  insuranceInfo    Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dependents       Dependent[]
  appointments     Appointment[]
  labResults       LabResult[]
  radiologyReports RadiologyReport[]
  prescriptions    Prescription[]
  bills            Bill[]
  medicalNotes     MedicalNote[]
  visitHistory     VisitHistory[]
  chatSessions     ChatSession[]
  waitlistEntries  WaitlistEntry[]

  @@map("patients")
}

model Dependent {
  id          String   @id @default(uuid())
  patientId   String
  nameAr      String
  nameEn      String?
  dateOfBirth DateTime
  gender      Gender
  relation    String
  nationalId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@map("dependents")
}

// ─────────────── DOCTORS ───────────────

model Doctor {
  id              String   @id @default(uuid())
  userId          String   @unique
  nameAr          String
  nameEn          String?
  specialtyId     String
  licenseNumber   String   @unique
  bio             String?
  consultationFee Decimal? @db.Decimal(10, 2)
  isAvailable     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty       Specialty @relation(fields: [specialtyId], references: [id])
  schedules       DoctorSchedule[]
  appointments    Appointment[]
  medicalNotes    MedicalNote[]
  prescriptions   Prescription[]
  waitlistEntries WaitlistEntry[]

  @@map("doctors")
}

model Specialty {
  id      String   @id @default(uuid())
  nameAr  String
  nameEn  String
  code    String   @unique
  icon    String?

  doctors Doctor[]

  @@map("specialties")
}

model DoctorSchedule {
  id           String    @id @default(uuid())
  doctorId     String
  dayOfWeek    DayOfWeek
  startTime    String
  endTime      String
  slotDuration Int       @default(20)
  maxPatients  Int       @default(1)
  isActive     Boolean   @default(true)
  branchId     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  doctor       Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  branch       Branch?   @relation(fields: [branchId], references: [id])
  blockedSlots BlockedSlot[]

  @@unique([doctorId, dayOfWeek, branchId])
  @@map("doctor_schedules")
}

model BlockedSlot {
  id         String   @id @default(uuid())
  scheduleId String
  date       DateTime @db.Date
  startTime  String
  endTime    String
  reason     String?
  createdAt  DateTime @default(now())

  schedule   DoctorSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@map("blocked_slots")
}

// ─────────────── BRANCHES ───────────────

model Branch {
  id        String   @id @default(uuid())
  nameAr    String
  nameEn    String?
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  schedules    DoctorSchedule[]
  appointments Appointment[]

  @@map("branches")
}

// ─────────────── APPOINTMENTS ───────────────

model Appointment {
  id              String            @id @default(uuid())
  referenceNumber String            @unique
  patientId       String
  dependentId     String?
  doctorId        String
  branchId        String?
  date            DateTime          @db.Date
  startTime       String
  endTime         String
  type            AppointmentType   @default(NEW_VISIT)
  status          AppointmentStatus @default(PENDING)
  reason          String?
  notes           String?
  cancelReason    String?
  reminderSent    Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  patient         Patient           @relation(fields: [patientId], references: [id])
  dependent       Dependent?        @relation(fields: [dependentId], references: [id])
  doctor          Doctor            @relation(fields: [doctorId], references: [id])
  branch          Branch?           @relation(fields: [branchId], references: [id])
  bill            Bill?
  visitHistory    VisitHistory?

  @@index([patientId, date])
  @@index([doctorId, date])
  @@index([date])
  @@index([status])
  @@map("appointments")
}

// ─────────────── MEDICAL RECORDS ───────────────

model VisitHistory {
  id             String      @id @default(uuid())
  patientId      String
  appointmentId  String      @unique
  doctorId       String
  visitDate      DateTime
  chiefComplaint String?
  diagnosis      String?
  treatmentPlan  String?
  followUpDate   DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  patient        Patient     @relation(fields: [patientId], references: [id])
  appointment    Appointment @relation(fields: [appointmentId], references: [id])

  @@index([patientId])
  @@map("visit_history")
}

model MedicalNote {
  id         String   @id @default(uuid())
  patientId  String
  doctorId   String
  content    String
  isDraft    Boolean  @default(true)
  approvedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  patient    Patient  @relation(fields: [patientId], references: [id])
  doctor     Doctor   @relation(fields: [doctorId], references: [id])

  @@map("medical_notes")
}

model LabResult {
  id         String          @id @default(uuid())
  patientId  String
  orderDate  DateTime
  resultDate DateTime?
  testName   String
  testCode   String?
  category   String?
  results    Json
  status     LabResultStatus @default(PENDING)
  isAbnormal Boolean         @default(false)
  notes      String?
  reportUrl  String?
  orderedBy  String?
  labName    String?
  createdAt  DateTime        @default(now())

  patient    Patient         @relation(fields: [patientId], references: [id])

  @@index([patientId, orderDate])
  @@map("lab_results")
}

model RadiologyReport {
  id              String   @id @default(uuid())
  patientId       String
  studyDate       DateTime
  modalityType    String
  bodyPart        String?
  indication      String?
  findings        String?
  impression      String?
  radiologistName String?
  facility        String?
  reportUrl       String?
  dicomUrl        String?
  thumbnailUrl    String?
  createdAt       DateTime @default(now())

  patient         Patient  @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@map("radiology_reports")
}

model Prescription {
  id          String   @id @default(uuid())
  patientId   String
  doctorId    String
  issueDate   DateTime
  expiryDate  DateTime?
  medications Json
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  patient     Patient  @relation(fields: [patientId], references: [id])
  doctor      Doctor   @relation(fields: [doctorId], references: [id])

  @@index([patientId])
  @@map("prescriptions")
}

// ─────────────── BILLING ───────────────

model Bill {
  id             String        @id @default(uuid())
  billNumber     String        @unique
  patientId      String
  appointmentId  String?       @unique
  issueDate      DateTime      @default(now())
  dueDate        DateTime?
  subtotal       Decimal       @db.Decimal(10, 2)
  discount       Decimal       @default(0) @db.Decimal(10, 2)
  tax            Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(10, 2)
  status         PaymentStatus @default(UNPAID)
  insuranceClaim Json?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  patient        Patient       @relation(fields: [patientId], references: [id])
  appointment    Appointment?  @relation(fields: [appointmentId], references: [id])
  items          BillItem[]
  payments       Payment[]

  @@index([patientId])
  @@map("bills")
}

model BillItem {
  id          String  @id @default(uuid())
  billId      String
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  bill        Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@map("bill_items")
}

model Payment {
  id            String        @id @default(uuid())
  billId        String
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  transactionId String?
  paidAt        DateTime      @default(now())
  notes         String?
  status        String        @default("SUCCESS")

  bill          Bill          @relation(fields: [billId], references: [id])

  @@map("payments")
}

// ─────────────── ADMIN ───────────────

model Admin {
  id        String   @id @default(uuid())
  userId    String   @unique
  nameAr    String
  nameEn    String?
  position  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

// ─────────────── NOTIFICATIONS ───────────────

model Notification {
  id        String              @id @default(uuid())
  userId    String
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String
  data      Json?
  isRead    Boolean             @default(false)
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ─────────────── AI ASSISTANT ───────────────

model ChatSession {
  id        String    @id @default(uuid())
  patientId String
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  patient   Patient   @relation(fields: [patientId], references: [id])
  messages  ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

// ─────────────── AUDIT LOG ───────────────

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@map("audit_logs")
}

// ─────────────── WAITLIST ───────────────

model WaitlistEntry {
  id             String   @id @default(uuid())
  patientId      String
  doctorId       String
  branchId       String?
  requestedDate  DateTime @db.Date
  preferredTimes String[]
  reason         String?
  status         String   @default("WAITING")
  notifiedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  patient        Patient  @relation(fields: [patientId], references: [id])
  doctor         Doctor   @relation(fields: [doctorId], references: [id])

  @@index([doctorId, requestedDate])
  @@index([patientId])
  @@map("waitlist_entries")
}