# ─────────────── SERVER ───────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ─────────────── DATABASE ───────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/2yhospital_db?schema=public"

# ─────────────── REDIS ───────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────── JWT ───────────────
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────── OTP ───────────────
OTP_EXPIRES_IN_MINUTES=5
OTP_LENGTH=6

# ─────────────── SMS PROVIDER ───────────────
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM_NUMBER=+1234567890

# ─────────────── AI ASSISTANT ───────────────
DEEPSEEK_API_KEY=your_deepseek_key
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# ─────────────── PAYMENT ───────────────
PAYMENT_GATEWAY=stripe
STRIPE_SECRET_KEY=your_stripe_secret

# ─────────────── CORS ───────────────
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8081

# ─────────────── RATE LIMITING ───────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─────────────── PAYMENT (STRIPE) ───────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─────────────── PUSH NOTIFICATIONS (FCM) ───────────────
FCM_SERVER_KEY=your_fcm_server_key
